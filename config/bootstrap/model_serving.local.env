# Copy this file to model_serving.env and edit the values.

# Python interpreter with sglang installed.
SGLANG_PYTHON_BIN="/projects/bdse/zhe3/uv_env/sglang/bin/python"

# Required: model path accessible on the serving machine.
SGLANG_MODEL_PATH="Kwai-Klear/Klear-AgentForge-8B"

# Launch mode:
# - single: one SGLang server process, optionally with tensor parallel
# - router: co-launch SGLang router + workers, useful for multi-GPU throughput
SGLANG_LAUNCH_MODE=router

# Network settings.
SGLANG_HOST=0.0.0.0
SGLANG_PORT=30000

# Parallelism / memory.
# In single mode, SGLANG_TP is the tensor parallel size.
# In router mode, SGLANG_TP is tp-size per worker group and SGLANG_DP_SIZE is the number of worker replicas.
SGLANG_TP=1
SGLANG_DP_SIZE=2
SGLANG_MEM_FRACTION_STATIC=0.80


# Optional.
# SGLANG_CONTEXT_LENGTH=32768
SGLANG_EXTRA_ARGS="--trust-remote-code"
# Router-only optional args, for example:
# SGLANG_ROUTER_EXTRA_ARGS=--router-policy round_robin

# Used by the OpenAI smoke test.
SGLANG_API_KEY="EMPTY"
SGLANG_MODEL_NAME="Kwai-Klear/Klear-AgentForge-8B"
SGLANG_SMOKE_PROMPT="Reply with exactly: bootstrap-ok"
