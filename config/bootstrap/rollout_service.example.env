# Copy this file to rollout_service.env and edit the values.

# Python interpreter used to run the rollout service.
BOOTSTRAP_PYTHON_BIN=python3

# Bind address for the rollout HTTP service on the rollout machine.
ROLLOUT_SERVICE_HOST=0.0.0.0
ROLLOUT_SERVICE_PORT=18080

# Directory where rollout jobs, logs, rendered configs, and artifacts are stored.
# Defaults to <repo>/outputs/rollout_service_jobs when unset.
# ROLLOUT_SERVICE_JOB_ROOT=/path/to/job_root

# Optional bearer token required by the rollout service.
# ROLLOUT_SERVICE_API_TOKEN=

# Maximum number of rollout jobs the service runs concurrently.
ROLLOUT_SERVICE_MAX_WORKERS=2
